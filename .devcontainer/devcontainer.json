{
  "name": "Python 3",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "backend/app.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "updateContentCommand": "sudo apt update && sudo apt install -y curl && curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - && sudo apt install -y nodejs && [ -f backend/requirements.txt ] && pip3 install --user -r backend/requirements.txt && cd frontend && npm install",
  "postAttachCommand": {
    "backend": "cd backend && uvicorn app:app --host 0.0.0.0 --port 8000 --reload",
    "frontend": "cd frontend && npm run dev"
  },
  "portsAttributes": {
    "5173": {
      "label": "Frontend Vite",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "Backend FastAPI"
    }
  },
  "forwardPorts": [
    5173,
    8000
  ]
}